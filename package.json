{
  "name": "w0pium",
  "version": "0.9.27",
  "description": "Minimalist dark social network formerly known as RAPNET",
  "main": "server.js",
  "scripts": {
    "start": "node -e \"const p=require('path');const j=process.env.npm_package_json;if(!j){console.error('Use: npm start');process.exit(1)}const r=p.dirname(j);if(!process.env.DATA_DIR)process.env.DATA_DIR=p.join(r,'data');require(p.join(r,'server.js'));\"",
    "dev": "vite",
    "build": "node scripts/build-static.js",
    "lint": "node scripts/run-eslint.js",
    "verify:quick": "node scripts/run-eslint.js && node scripts/audit-inline-handlers.js",
    "format": "prettier --write .",
    "e2e:smoke": "playwright test tests/e2e/smoke.spec.js --config=playwright.config.js --project=chromium",
    "e2e:smoke:prod": "playwright test tests/e2e/smoke.spec.js --config=playwright.prod.config.js --project=chromium",
    "e2e:dm": "playwright test tests/e2e/dm.spec.js --config=playwright.config.js --project=chromium",
    "e2e:dm:prod": "playwright test tests/e2e/dm.spec.js --config=playwright.prod.config.js --project=chromium",
    "e2e:visual": "playwright test tests/e2e/visual-2_0.spec.js --config=playwright.config.js --project=chromium",
    "seed:2.0": "node scripts/seed-2.0.js",
    "reset:wf-vf": "node scripts/reset-wf-vf.js",
    "e2e:smoke:all": "node scripts/run-e2e-all.js",
    "e2e:smoke:all:continue": "node scripts/run-e2e-all.js --continue-on-fail",
    "audit:inline-handlers": "node scripts/audit-inline-handlers.js",
    "deploy:guard": "sh scripts/predeploy-and-deploy.sh",
    "smoke:nightly": "sh scripts/nightly-prod-smoke.sh",
    "pipeline:auto": "sh scripts/auto-pipeline.sh",
    "ops:checklist": "sh scripts/checklist.sh",
    "ops:status": "sh scripts/status-report.sh",
    "ops:rollback": "sh scripts/rollback-safe.sh",
    "e2e:docker:smoke": "sh scripts/e2e-docker.sh smoke",
    "e2e:docker:smoke:prod": "sh scripts/e2e-docker.sh smoke-prod",
    "e2e:docker:dm:prod": "sh scripts/e2e-docker.sh dm-prod",
    "e2e:install": "playwright install chromium",
    "rebuild:native": "node -e \"const p=require('path'),cp=require('child_process');const j=process.env.npm_package_json;if(!j){console.error('Run: npm run rebuild:native (from this package)');process.exit(1)}const r=p.dirname(j),s=p.join(r,'scripts','rebuild-native.js');const c=cp.spawnSync(process.execPath,[s],{stdio:'inherit',env:process.env,cwd:r});process.exit(c.status===null?1:c.status);\"",
    "prepare": "node scripts/prepare-husky.js"
  },
  "dependencies": {
    "archiver": "^7.0.1",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^12.9.0",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.1",
    "helmet": "^8.0.0",
    "multer": "^2.1.1",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "sharp": "^0.33.5",
    "uuid": "^10.0.0",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@playwright/test": "^1.59.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.13.0",
    "globals": "^15.11.0",
    "husky": "^9.1.6",
    "lint-staged": "^15.2.10",
    "postcss": "^8.4.47",
    "prettier": "^3.3.3",
    "tailwindcss": "^3.4.14",
    "vite": "^5.4.10"
  },
  "lint-staged": {
    "*.js": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md}": "prettier --write"
  }
}
