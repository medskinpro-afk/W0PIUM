# Server
PORT=3000
W0PIUM_BIND_ADDR=127.0.0.1
W0PIUM_HOST_PORT=3000
NODE_ENV=development

# Data storage (absolute or relative path)
DATA_DIR=./data

# Logging level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# Registration — keep INVITE_ONLY=1 in production to block open sign-ups
INVITE_ONLY=1
# Change MASTER_CODE from the default before deploying
MASTER_CODE=change_this_before_deploying

# Email — Resend API (https://resend.com)
# Leave empty to fall back to console.log in development
RESEND_API_KEY=
EMAIL_FROM=onboarding@resend.dev

# Email encryption key — 64 hex chars (32 bytes). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Without this, a dev fallback is used (NOT safe for production!)
ENCRYPTION_KEY=

# Web Push (VAPID) — generate with: node -e "require('web-push').generateVAPIDKeys()" then set both
VAPID_PUBLIC=
VAPID_PRIVATE=

# Cloudflare Tunnel token — from Cloudflare One → Networks → Connectors → your tunnel
CLOUDFLARE_TUNNEL_TOKEN=

# One-off recovery only: grant admin to this username at startup (leave empty by default)
BOOTSTRAP_ADMIN_USERNAME=
