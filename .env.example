# Server
PORT=3000
NODE_ENV=development

# Data storage (absolute or relative path)
DATA_DIR=./data

# Logging level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# Registration
# Set to '1' to require invite codes for all new registrations
INVITE_ONLY=0
# Master invite code that always works (used for first admin signup)
MASTER_CODE=W0PIUM

# Email — Resend API (https://resend.com)
# Leave empty to fall back to console.log in development
RESEND_API_KEY=
EMAIL_FROM=onboarding@resend.dev

# Email encryption key — 64 hex chars (32 bytes). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Without this, a dev fallback is used (NOT safe for production!)
ENCRYPTION_KEY=

# Web Push (VAPID) — generate with: node -e "require('web-push').generateVAPIDKeys()" then set both
VAPID_PUBLIC=
VAPID_PRIVATE=

# Cloudflare Tunnel token — from Cloudflare One → Networks → Connectors → your tunnel
CLOUDFLARE_TUNNEL_TOKEN=
